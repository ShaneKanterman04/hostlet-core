POSTGRES_USER=hostlet
POSTGRES_PASSWORD=change-me-local-postgres-password
POSTGRES_DB=hostlet
DOCKER_GID=
DATABASE_URL=postgres://hostlet:CHANGE_ME@localhost:5432/hostlet
BIND_ADDR=0.0.0.0:8080
PUBLIC_API_URL=http://localhost:8080
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_WEBHOOK_URL=
HOSTLET_CONTROL_PLANE_HOST=localhost
# Drives "Visit" links for apps that are not publicly exposed (no public subdomain).
HOSTLET_PRIVATE_APP_HOST=127.0.0.1
HOSTLET_ALLOWED_WEB_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
HOSTLET_BASE_DOMAIN=
HOSTLET_DOMAIN_PREFIX=hostlet-
HOSTLET_CADDYFILE=./Caddyfile.tunnel
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_TARGET=
CLOUDFLARE_TUNNEL_TOKEN=
HOSTLET_ALLOW_INSECURE_DEV_DEFAULTS=false
HOSTLET_SETUP_TOKEN=replace-with-32-plus-random-characters
ENCRYPTION_KEY=replace-with-base64-32-byte-key
JOB_SIGNING_SECRET=replace-with-32-plus-random-characters
SESSION_SECRET=replace-with-32-plus-random-characters
LOCAL_SERVER_ID=00000000-0000-0000-0000-000000000001
LOCAL_AGENT_TOKEN=replace-with-32-plus-random-characters
GITHUB_WEBHOOK_SECRET=replace-with-32-plus-random-characters
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
HOSTLET_ALLOWED_GITHUB_LOGINS=

# Compose-only / release image vars (managed by `hostlet update`; not read by the CLI).
# HOSTLET_IMAGE_TAG=          # prod image selection; set to a Hostlet release tag
# HOSTLET_IMAGE_REGISTRY=     # prod image registry; defaults to ghcr.io/shanekanterman04

# Optional cleanup tuning (see apps/api/src/cleanup.rs).
# HOSTLET_AUTO_CLEANUP=
# HOSTLET_CLEANUP_KEEP_PREVIOUS=
# HOSTLET_CLEANUP_KEEP_FAILED_HOURS=

# Agent BuildKit + health-check tuning (see docs/deploying-apps.md).
# HOSTLET_RAILPACK_BUILDKIT_IMAGE=
# HOSTLET_RAILPACK_BUILDKIT_KEEPALIVE=
# HOSTLET_RAILPACK_BUILDKIT_IDLE_SECONDS=
# HOSTLET_RAILPACK_BUILDKIT_READY_TIMEOUT_SECS=
# HOSTLET_RAILPACK_BUILDKIT_MEMORY_LIMIT_MB=
# HOSTLET_HEALTH_CHECK_ATTEMPTS=
