http://{$HOSTLET_CONTROL_PLANE_HOST:hostlet.cloud} {
	@api path /api/* /auth/* /webhooks/* /install-agent.sh /ws/* /health
	reverse_proxy @api 127.0.0.1:8080
	reverse_proxy 127.0.0.1:3000
}

http://*.{$HOSTLET_APPS_HOST:hostlet.cloud} {
	route {
		import /var/lib/hostlet/caddy/*.caddy
		respond "not found" 404
	}
}
